<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Entre em contato com nossa equipe de suporte técnico.">
    <title>Área de Contato do Cliente – Suporte Tech<title>
<head>
<body>
    <header>
        <h1>Área de Contato do Cliente<h1>
        <nav>
            <a href="#">Ajuda<a> | <a href="#">Sair<a>
        <nav>
    <header>

    <main>
        <h2>Envie sua mensagem para a nossa equipe de suporte backend<h2>

        <form action="/enviar" method="POST">

            <label for="nome">Nome:<label>
            <input type="text" id="nome" name="nome" required>

            <label for="email">Email:</label><br>
            <input type="email" id="email" name="email" required>

            <label for="celular">Telefone Celular:<label>
            <input
                type="tel"
                id="celular"
                name="celular"
                pattern="[0-9]{2}9[0-9]{8}"
                title="Informe DDD + 9 dígitos, somente números (ex: 22999998888)"

            <label for="msg">Mensagem:<label>
            <textarea id="msg" name="msg" required><textarea>

            <button type="submit">enviar<button>

        <form>
    <main>

    <footer>
        <p>Suporte Tech 2026<p>
    <footer>

<body>
<html>
